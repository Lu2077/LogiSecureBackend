# backend/.env
# ==============================================================================
# LOGISECURE AI - GLOBAL CONFIGURATION ENVIRONMENT VARIABLES
# NEVER commit the real '.env' file — it is covered by .gitignore.
# ==============================================================================

# ── SERVER ────────────────────────────────────────────────────────────────────
BACKEND_ENV=development
HOST=0.0.0.0
PORT=8000
DEBUG=True
CONFIDENCE_THRESHOLD=0.7
USE_MOCK_DATA=True
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173,http://localhost:8000

# ── 1. AIR TRAFFIC: OpenSky Network (Basic Auth) ─────────────────────────────
# Register at https://opensky-network.org ("Register"). Works anonymously
# with lower rate limits if left empty.
OPENSKY_USERNAME=
OPENSKY_PASSWORD=

# ── 2. MARITIME TRAFFIC: AISstream / VesselAPI (API Key) ─────────────────────
# Free key at https://aisstream.io ("Get API Key"). If empty, the backend
# serves a mock vessel feed so the frontend keeps working.
AISSTREAM_API_KEY=

# ── 3. REMOTE AI: Fireworks AI (shared hackathon credits) ────────────────────
# YOUR ACTUAL FIREWORKS API KEY - KEEP THIS!
FIREWORKS_API_KEY=fw_BKbdwA3hHumdmnXzjSSoTh
FIREWORKS_MODEL=accounts/fireworks/models/llama-v3p1-8b-instruct
FIREWORKS_BASE_URL=https://api.fireworks.ai/inference/v1

# ── 3b. REMOTE AI: Groq (fallback) ──────────────────────────────────────────
GROQ_API_KEY=

# ── 4. LLM SETTINGS ──────────────────────────────────────────────────────────
LLM_TEMPERATURE=0.3
LLM_MAX_TOKENS=500

# ── 5. LOCAL AI ENGINE (Enterprise on-premise target only) ───────────────────
# Keep False on team laptops: inference is routed through cloud APIs instead
# of the AMD ROCm stack.
USE_AMD_ROCM=False
LOCAL_MODEL_PATH=./models/gemma-4-e4b.gguf

# ── KEYLESS PUBLIC FEEDS (no configuration needed, listed for reference) ─────
# Weather:            https://open-meteo.com          (free, no key)
# Land routing:       http://project-osrm.org         (free, no key)
# Disaster alerts:    https://gdacs.org               (UN GDACS RSS, free)
# Geopolitical feed:  https://gdeltproject.org        (free)